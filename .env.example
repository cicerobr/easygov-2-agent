# EasyGov - Environment Variables

# Neon Database
DATABASE_URL=postgresql://neondb_owner:<password>@ep-jolly-butterfly-aky328pg-pooler.c-3.us-west-2.aws.neon.tech/neondb?sslmode=require

# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=<generate-with-openssl-rand-base64-32>

# OAuth Providers (NextAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# LLM (Agent)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_OCR_MODEL=gpt-4.1-mini
OCR_ENABLED=true
OCR_MIN_CHARS_PER_PAGE=80
OCR_PAGE_RENDER_DPI=200
OCR_REQUEST_TIMEOUT_SEC=45
OCR_MAX_RETRIES=2
OCR_MAX_CONCURRENCY=2

# LangSmith (optional observability for LangChain/LangGraph)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=easygov

# Email Notifications (Resend)
RESEND_API_KEY=

# Cloudflare R2 (File Storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=easygov-docs

# WhatsApp Notifications (optional)
WHATSAPP_API_URL=
WHATSAPP_API_KEY=
